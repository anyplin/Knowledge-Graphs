@base <https://anyplin.github.io/Knowledge-Graphs/data.ttl> .
@prefix vocab: <https://anyplin.github.io/Knowledge-Graphs/vocab.ttl#> .
@prefix jn: <https://jellenelis.github.io/knowledge-graphs/data.ttl#> .
@prefix km: <https://kellymarino.github.io/knowledge-graphs-2026/data.ttl#> .
@prefix seppe: <https://seppesantens.github.io/rdf-lab2/data.ttl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Instances
<#Germany> a vocab:Country ;
rdfs:label "Germany"@en ;
rdfs:comment "Country in central Europe."@en .

<#Spain> a vocab:Country ;
rdfs:label "Spain"@en ;
rdfs:comment "Country in western Europe."@en .

<#Beach> a vocab:Thing ;
rdfs:label "beach"@en ;
rdfs:comment "An area of sand or small stones near the sea or another area of water such as a lake."@en .

<#QueensHead> a vocab:Thing ;
rdfs:label "Queen's Head"@en ;
rdfs:comment "A landmark mushroom rock formation at Yehliu Geopark."@en .

<#Taiwan> a vocab:Country ;
rdfs:label "Taiwan"@en ;
rdfs:comment "Country in East Asia."@en .

<#Gent> a vocab:City ;
rdfs:label "Gent"@en ;
rdfs:comment "A specific instance of a city or administrative area representing Gent, Belgium."@en .

<#MasterOfComputerScience> a vocab:CourseOfStudy ;
rdfs:label "Master of Computer Science"@en ;
rdfs:comment "A university degree focused on advanced computing theory, software development, and information systems."@en .

<#WinterCircus> a vocab:StartUpHub ;
rdfs:label "Wintercircus"@en ;
rdfs:comment "A specific instance of a technology hub representing the Wintercircus in Ghent, which provides a collaborative ecosystem for entrepreneurs and high-tech organizations."@en ;
vocab:location <#Gent> .

<#HydrosyncAi> a vocab:StartUpCompany ;
rdfs:label "Hydrosync.ai"@en ;
rdfs:comment "A specific instance of the start-up company representing the organization hydrosync.ai, who is focusing on accelerating the decarbonization of buildings by utilizing IoT sensor networks and AI-driven insights to optimize indoor climate comfort and reduce energy waste."@en ;
vocab:basedAt <#WinterCircus> .

<#KnowledgeGraphs> a vocab:Course ;
rdfs:label "Knowledge Graph"@en ;
rdfs:comment "The course Knowledge graph which is offered by the University of Gent in Belgium."@en .

<#Anna> a vocab:Person ;
rdfs:label "Anna"@en ;
rdfs:comment "An individual record representing the personal, educational, and cultural background of Anna."@en ;
vocab:name "Anna Lin" ;
vocab:origin <#Germany> ;
vocab:familyOrigin <#Taiwan> ;
vocab:graduated <#MasterOfComputerScience> ;
vocab:worksFor <#HydrosyncAi> ;
vocab:workLocation <#WinterCircus> ;
vocab:courseParticipant <#KnowledgeGraphs> ;
vocab:knows jn:JelleNelis, km:MyName, seppe:me .

km:MyName vocab:courseParticipant <#KnowledgeGraphs> .

<#PaintedAnimationLane> a vocab:Photograph ;
vocab:titled "Painted Animation Lane"@en ;
vocab:depicts <#Anna> ;
vocab:pictureLocation <#Taiwan> ;
vocab:describes "Anna, brother and friends posting as One Piece characters at the Painted Animation Lane in Taichung."@en ;
